<Window x:Class="Murmur.App.ModelDownloadWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Murmur — Downloading model"
        Width="420"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True">
    <StackPanel Margin="20">
        <TextBlock Text="Downloading speech model" FontSize="16" FontWeight="SemiBold" />
        <TextBlock x:Name="DetailText"
                   Text="This happens once and stays on your PC. No audio ever leaves your machine."
                   Foreground="Gray" TextWrapping="Wrap" Margin="0,4,0,14" />
        <ProgressBar x:Name="Bar" Height="20" Minimum="0" Maximum="100" />
        <TextBlock x:Name="PercentText" Text="Starting…" Margin="0,8,0,0" HorizontalAlignment="Right" />
    </StackPanel>
</Window>
