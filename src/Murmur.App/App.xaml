<Application x:Class="Murmur.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Murmur.App"
             ShutdownMode="OnExplicitShutdown">
    <!-- No StartupUri: Murmur is a tray-only app with no main window.
         OnExplicitShutdown keeps the process alive without any window open. -->
    <Application.Resources>
    </Application.Resources>
</Application>
