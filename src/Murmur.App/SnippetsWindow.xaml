<Window x:Class="Murmur.App.SnippetsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Murmur — Voice Shortcuts"
        Width="560"
        Height="420"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Voice shortcuts" FontSize="18" FontWeight="SemiBold" />
            <TextBlock Foreground="Gray" TextWrapping="Wrap" Margin="0,4,0,0">
                Say a trigger phrase on its own and Murmur types the expansion instead.
                Example: trigger "my email" → "you@example.com".
            </TextBlock>
        </StackPanel>

        <DataGrid Grid.Row="1" x:Name="Grid" AutoGenerateColumns="False"
                  CanUserAddRows="True" CanUserDeleteRows="True" HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal" RowHeaderWidth="0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="When I say…" Binding="{Binding Trigger}" Width="200" />
                <DataGridTextColumn Header="Type this" Binding="{Binding Expansion}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button x:Name="RemoveButton" Content="Remove selected" Width="130" Height="30"
                    Margin="0,0,8,0" Click="OnRemove" />
            <Button Content="Save" Width="90" Height="30" IsDefault="True" Click="OnSave"
                    Margin="0,0,8,0" />
            <Button Content="Cancel" Width="90" Height="30" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
